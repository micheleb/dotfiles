{
  "permissions": {
    "allow": [
      "Bash(./gradlew:*)",
      "Bash(adb devices:*)",
      "Bash(cat:*)",
      "Bash(done)",
      "Bash(echo:*)",
      "Bash(emulator -list-avds:*)",
      "Bash(find:*)",
      "Bash(git --no-pager diff:*)",
      "Bash(git --no-pager log:*)",
      "Bash(git bisect:*)",
      "Bash(git checkout:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git grep:*)",
      "Bash(git log:*)",
      "Bash(git ls-tree:*)",
      "Bash(git merge-base:*)",
      "Bash(git show:*)",
      "Bash(git stash:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(npm i)",
      "Bash(npx eslint:*)",
      "Bash(npx react-native:*)",
      "Bash(npx tsc:*)",
      "Bash(tee:*)",
      "Read(//tmp/**)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:medium.com)",
      "WebFetch(domain:playwright.dev)",
      "WebFetch(domain:stackoverflow.com)",
      "WebSearch",
      "mcp__ide__getDiagnostics"
    ],
    "deny": [],
    "defaultMode": "default"
  },
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "autoMemoryEnabled": false,
  "voiceEnabled": true,
  "model": "opus[1m]",
  "preferredNotifChannel": "terminal_bell",
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$TMUX_PANE\" ] && tmux set-option -p -t \"$TMUX_PANE\" @claude_attention 1 || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$TMUX_PANE\" ] && tmux set-option -p -t \"$TMUX_PANE\" @claude_attention 1 || true"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$TMUX_PANE\" ] && tmux set-option -pu -t \"$TMUX_PANE\" @claude_attention || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$TMUX_PANE\" ] && tmux set-option -pu -t \"$TMUX_PANE\" @claude_attention || true"
          }
        ]
      }
    ]
  }
}